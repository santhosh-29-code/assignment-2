#include <stdio.h>

#define MAX 100

int stack[MAX];
int top = -1;

// Push
void push(int x) {
    stack[++top] = x;
}

// Pop
int pop() {
    return stack[top--];
}

// Check empty
int isEmpty() {
    return top == -1;
}

int main() {
    int arr[MAX], n, i;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements: ");
    for (i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    // Push first element
    push(arr[0]);

    // Traverse rest
    for (i = 1; i < n; i++) {
        int next = arr[i];

        // Compare with stack elements
        while (!isEmpty() && stack[top] < next) {
            printf("%d -> %d\n", pop(), next);
        }

        push(next);
    }

    // Remaining elements
    while (!isEmpty()) {
        printf("%d -> -1\n", pop());
    }

    return 0;
}
